# Database
DATABASE_URL=postgresql://...

# Auth (better-auth)
BETTER_AUTH_SECRET=...
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI — used by the LiveKit agent (GA Realtime API) and summarization
OPENAI_API_KEY=sk-...

# LiveKit — required for video calls and the AI agent (see LIVEKIT_MIGRATION.md)
# Get these from https://cloud.livekit.io → your project → Settings → Keys
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_LIVEKIT_URL=wss://your-app.livekit.cloud

# Stream Chat — still used for post-meeting chat
NEXT_PUBLIC_STREAM_CHAT_API_KEY=...
STREAM_CHAT_SECRET=...

# Stream Video — legacy, removed after LiveKit migration completes
NEXT_PUBLIC_STREAM_API_KEY=...
STREAM_VIDEO_SECRET=...

# Polar (billing)
POLAR_ACCESS_TOKEN=...
